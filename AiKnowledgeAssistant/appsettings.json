{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Rag": {
    "Ranker": "local_reranker",
    "VectorTopK": 50,
    "FinalTopK": 3
  },
  "Ranker": {
    "ModelPath": "Models/model.onnx",
    "TokenizerPath": "Models/tokenizer.json"
  },
  "AzureOpenAI": {
    "ChatDeploymentName": "gpt-4-chat",
    "EmbeddingDeploymentName": "text-embedding-ada-002"
  },
  "Ingestion": {
    "DocumentAnalysisModelId": "prebuilt-document",
    "MaxTokensPerLine": 100,
    "MaxTokensPerParagraph": 1000,
    "MaxConcurrentIngestions": 50
  }
}
